# Target Kubernetes namespace
TARGET_NAMESPACE=amtd

# Target agent container image
AGENT_IMAGE=amtd-agent:latest

# Rotation interval in seconds
EPOCH_DURATION_SEC=300

# Number of pre-scheduled warm standby pods
WARM_POOL_SIZE=2

# Port of the controller HTTP API
CONTROLLER_PORT=8080

# Formal verification Engine binary paths (Default: 'lean' and 'z3' in system PATH)
# LEAN4_BINARY=lean
# Z3_BINARY=z3

# Local storage databases
FACT_GRAPH_PATH=fact_graph.json
LEDGER_PATH=ledger.json

# LLM API Key and HMAC signing secret (highly confidential!)
LLM_API_KEY=your-llm-api-key-here
